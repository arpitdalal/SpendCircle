{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "overrides": [
      {
        "files": ["**/components/ui/input-group.tsx"],
        "rules": ["react-doctor/prefer-tag-over-role", "react-doctor/no-multi-comp"]
      },
      {
        "files": ["**/components/ui/label.tsx"],
        "rules": ["react-doctor/label-has-associated-control"]
      },
      {
        "files": ["**/app/components/ui/debounced-search-input.tsx"],
        "rules": [
          "react-doctor/no-derived-state",
          "react-doctor/no-reset-all-state-on-prop-change",
          "react-doctor/no-event-handler"
        ]
      },
      {
        "files": ["**/app/routes/circle/categories.tsx"],
        "rules": [
          "react-doctor/no-event-handler",
          "react-doctor/no-prop-callback-in-effect",
          "react-doctor/no-chain-state-updates"
        ]
      },
      {
        "files": ["**/app/lib/form.tsx"],
        "rules": ["react-doctor/no-multi-comp", "react-doctor/only-export-components"]
      },
      {
        "files": ["**/app/routes/circle/dashboard-comparison-chart.tsx"],
        "rules": ["react-doctor/prefer-dynamic-import"]
      },
      {
        "files": ["**/app/lib/use-resolved-ref.ts"],
        "rules": ["react-doctor/no-event-handler"]
      },
      {
        "files": ["**/app/lib/route-skeleton.ts"],
        "rules": ["react-doctor/no-event-handler"]
      },
      {
        "files": ["**/app/routes/circle/transactions.tsx"],
        "rules": ["react-doctor/no-derived-state", "react-doctor/no-event-handler"]
      },
      {
        "files": [
          "**/app/components/category-form.tsx",
          "**/app/routes/circle/settings.tsx",
          "**/app/routes/circle-new.tsx"
        ],
        "rules": ["react-doctor/prefer-useReducer"]
      },
      {
        "files": ["package.json"],
        "rules": ["deslop/unused-dependency"]
      }
    ]
  }
}
