{
  "extends": "../../tsconfig.base.json",
  "include": [
    ".react-router/types/**/*",
    "app/**/*",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "rootDirs": [".", "./.react-router/types"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "~/*": ["./app/*"]
    }
  }
}
