{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true
  },
  "include": ["convex/**/*.ts", "convex/**/*.tsx", "test/**/*.ts"],
  "exclude": ["convex/_generated", "convex/**/*.test.ts"]
}
