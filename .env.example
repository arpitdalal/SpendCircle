# Read by the web app (apps/web-app/vite.config.ts sets envDir to the repo
# root). Copy to .env.local and fill in.
#
# NOTE: CONVEX_DEPLOYMENT does NOT go here — the Convex CLI runs from
# packages/convex and manages packages/convex/.env.local itself on first
# `pnpm --filter @spend-circle/convex dev` run.
#
# Secret lines below use the form VAR=<placeholder>.
VITE_CONVEX_URL=https://<your-deployment>.convex.cloud
VITE_CONVEX_SITE_URL=https://<your-deployment>.convex.site
# App origin Better Auth redirects back to (also set on the Convex deployment)
SITE_URL=http://127.0.0.1:5173
BETTER_AUTH_SECRET=<random-secret>
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
