# Convex dev deployment (from `npx convex dev` / dashboard). Value shape is
# always `NAME=<placeholder>` here — never paste real secrets into this file.
CONVEX_DEPLOYMENT=dev:<your-convex-dev-deployment>
VITE_CONVEX_URL=https://<your-deployment>.convex.cloud
VITE_CONVEX_SITE_URL=https://<your-deployment>.convex.site
# App origin used by Better Auth
SITE_URL=http://127.0.0.1:5173
BETTER_AUTH_SECRET=<random-secret>
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
